#!/usr/bin/env bash
# Pull runtime changes to a vault's .obsidian config back into the dotfiles repo,
# then show the diff so you can review and commit. Counterpart to ./install,
# which rsyncs repo -> vault. Config is copy-managed (not symlinked). Syncs
# CONFIG JSON only — never plugin binaries or the generator-owned types.json /
# runtime workspace files.
#
# Usage: obsidian-config-sync [habits|lingo]   (default: all vaults)
set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/6eniu5/dotfiles}"
CONTAINER="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents"
FILES="app.json appearance.json core-plugins.json community-plugins.json daily-notes.json templates.json"
ANY=0

sync_vault() { # $1 = subdir name, $2 = vault path
  local name="$1" src="$2/.obsidian" dst="$DOTFILES/obsidian/$1/vault-obsidian" f
  [ -d "$src" ] || { echo "skip $name: no $src (is the vault set up?)"; return 0; }
  for f in $FILES; do
    if [ -f "$src/$f" ] && [ -f "$dst/$f" ] && ! cmp -s "$src/$f" "$dst/$f"; then
      cp "$src/$f" "$dst/$f"
      echo "synced: $name/$f"
      ANY=1
    fi
  done
}

target="${1:-all}"
if [ "$target" = all ] || [ "$target" = habits ]; then
  sync_vault habits "${OBSIDIAN_HABITS_VAULT:-$CONTAINER/Habits}"
fi
if [ "$target" = all ] || [ "$target" = lingo ]; then
  sync_vault lingo "${OBSIDIAN_LINGO_VAULT:-$CONTAINER/Lingo}"
fi

if [ "$ANY" -eq 0 ]; then
  echo "obsidian config already in sync with the repo — nothing to do."
  exit 0
fi

echo
git -C "$DOTFILES" --no-pager diff -- obsidian || true
echo
echo "Review the diff, then commit:"
echo "  git -C \"$DOTFILES\" add obsidian && git -C \"$DOTFILES\" commit"
