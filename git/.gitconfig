[user]
	name = kernvex
	email = kernvex@gmail.com
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[alias]
	pr = pull --rebase
[push]
	autoSetupRemote = true
# Machine/identity-local git config (per-company includeIf blocks, etc.). Kept
# OUT of this public repo. Missing file = silently ignored. Placed last so its
# includeIf'd identities override the personal [user] above for their folders.
# See the `ssh` repo's ADDING_AN_IDENTITY.md.
[include]
	path = ~/.config/git/local.inc
